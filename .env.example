# Unraid 推荐：/mnt/user/appdata/happy-kitchen/data
APPDATA_PATH=./data

# 仅在受信任的家庭局域网直连时使用 0.0.0.0；绝不要配置路由器端口映射或 UPnP。
# 若只希望 NAS 本机能访问，请改为 127.0.0.1。
HOST_BIND_ADDRESS=0.0.0.0

# 宿主机端口：容器内应用始终使用 3000，此处决定 NAS 的访问端口。
HOST_PORT=3000

# Unraid 默认 nobody:users；若目录使用其他属主请相应调整。
PUID=99
PGID=100
TZ=Asia/Shanghai
